
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

PORT=3000
NODE_ENV=development

CORS_ORIGIN=http://localhost:3000,http://localhost:8081


APP_URL=http://localhost:3000
PASSWORD_RESET_REDIRECT_URL=http://localhost:3000/reset-password


# ─────────────────────────────────────────────────
# SMTP — Email delivery for OTP codes
# ─────────────────────────────────────────────────
# The app uses Nodemailer to send OTP emails directly.
# This is REQUIRED for OTP emails to be delivered in production.
#
# In development: if SMTP_HOST is not set, OTP codes are printed
# to the terminal console instead of being emailed (safe for local testing).
#
# ── OPTION 1: Gmail (quick for testing) ──────────
# 1. Enable 2-step verification on your Google account
# 2. Go to Google Account → Security → App Passwords
# 3. Generate an app password for "Mail"
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-gmail@gmail.com
# SMTP_PASS=your-16-char-app-password
#
# ── OPTION 2: Resend (recommended for production) ─
# 1. Sign up at https://resend.com (free tier: 100 emails/day)
# 2. Get your API key from the dashboard
# 3. Add and verify your sending domain
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_your_api_key_here
#
# ── OPTION 3: SendGrid ────────────────────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
#
# ── Fill in your chosen option below: ────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=PCOSAPI
SMTP_FROM_EMAIL=noreply@yourdomain.com
